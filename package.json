{
  "name": "predexec",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Predictive execution: collapse an adaptive multi-level tool sequence into a single model round-trip via a deterministic plan tree. pi coding agent extension / opencode plugin.",
  "keywords": [
    "pi-package"
  ],
  "main": ".opencode/plugins/predexec.ts",
  "pi": {
    "extensions": [
      "./.pi/extension/index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.8",
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "@opencode-ai/plugin": "^1.17.9",
    "@types/node": "24.12.4",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
