{
  "name": "predexec",
  "version": "0.1.3",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "description": "Predictive execution: collapse an adaptive multi-level tool sequence into a single model round-trip via a deterministic plan tree. pi coding agent extension / opencode plugin.",
  "author": "FuriousZen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FuriousZen/predexec.git"
  },
  "homepage": "https://github.com/FuriousZen/predexec#readme",
  "bugs": "https://github.com/FuriousZen/predexec/issues",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "pi-package"
  ],
  "main": ".opencode/plugins/predexec.ts",
  "bin": {
    "predexec": "./bin/predexec.mjs"
  },
  "files": [
    ".pi",
    ".opencode",
    "bin",
    "core",
    "skills",
    "configs",
    "steering.ts",
    "stats.ts",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./.pi/extension/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run typecheck"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.8",
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "@opencode-ai/plugin": "^1.17.9",
    "@types/node": "24.12.4",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "zod": "~4.1.8"
  }
}
